# ============================================================
# CryptoEngine Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Exchange: Bybit ──────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# ── Data Provider: CoinGlass ─────────────────────────────────
COINGLASS_API_KEY=your_coinglass_api_key_here

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=change_me_to_a_strong_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── LLM Advisor ──────────────────────────────────────────────
CLAUDE_CODE_PATH=/usr/local/bin/claude

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_INTERNAL_PORT=3000
DASHBOARD_PUBLIC_PORT=3001

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ── General ───────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=testnet

# ── Phase 5: 소액 실전 모드 ────────────────────────────────────
# BYBIT_TESTNET=false 로 전환 시 아래 항목도 함께 설정
# PHASE5_MODE=true                       # 명시적 Phase 5 활성화 (BYBIT_TESTNET=false 시 자동)
# EXPECTED_INITIAL_BALANCE_USD=200       # 시작 잔고 검증 (시작 시 실잔고와 비교)
# STRICT_MONITORING_HOURS=24             # 첫 N시간 강화 모니터링 (1시간마다 상태 리포트)

# ====== LLM Advisor: Data Sources (Free Tier Only) ======

# FRED (already provisioned)
FRED_API_KEY=your_fred_key_here

# Free sources — no API keys required:
# - Farside Investors (HTML scraping)
# - SoSoValue (HTML scraping, backup for Farside)
# - CoinMetrics Community API (no key)
# - mempool.space (no key)
# - Binance Public Futures API (no key)
# - Bybit Public API (no key)
# - Messari/Bitwise/Glassnode Insights RSS (no key)

# ====== Alert System ======
ALERT_DIR=./alerts
ALERT_LOG_FILE=./logs/data_source_health.log
ALERT_DEDUP_WINDOW_SECONDS=3600

# Optional alert webhooks
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# ====== Caching ======
DATA_CACHE_DIR=./cache/data_sources
ETF_CACHE_TTL_SECONDS=43200
ONCHAIN_CACHE_TTL_SECONDS=3600
DERIVATIVES_CACHE_TTL_SECONDS=900
RESEARCH_CACHE_TTL_SECONDS=21600
MACRO_CACHE_TTL_SECONDS=3600

# ====== Scraping Behavior ======
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; BitManiaResearch/1.0)
SCRAPE_REQUEST_TIMEOUT_SECONDS=20
SCRAPE_MAX_RETRIES=2
SCRAPE_RETRY_BACKOFF_SECONDS=5

# Fallback LLM for research summarization
SUMMARY_LLM_MODEL=claude-haiku-4-5-20251001
