      "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres"}, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  strategy_id AS \"전략\",\n  symbol AS \"심볼\",\n  side AS \"방향\",\n  ROUND(size::numeric, 6) AS \"수량\",\n  ROUND(entry_price::numeric, 2) AS \"진입가\",\n  ROUND(current_price::numeric, 2) AS \"현재가\",\n  ROUND(COALESCE(unrealized_pnl, 0)::numeric, 4) AS \"미실현 PnL\",\n  COALESCE(leverage, 1) AS \"레버리지\",\n  ROUND((entry_price * size / NULLIF(leverage, 0))::numeric, 2) AS \"증거금\",\n  ROUND(EXTRACT(EPOCH FROM NOW() - opened_at) / 3600, 1) AS \"보유시간(h)\",\n  opened_at AS \"진입 시각\"\nFROM positions\nWHERE closed_at IS NULL\nORDER BY opened_at DESC", "refId": "A"}],
