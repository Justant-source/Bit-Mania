      "pluginVersion": "10.0.0",
      "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres"}, "editorMode": "code", "format": "table", "rawQuery": true, "rawSql": "SELECT\n  COALESCE(filled_at, created_at) AS \"체결 시각\",\n  strategy_id AS \"전략\",\n  symbol AS \"심볼\",\n  side AS \"방향\",\n  order_type AS \"주문 유형\",\n  ROUND(COALESCE(quantity, 0)::numeric, 6) AS \"수량\",\n  ROUND(COALESCE(price, 0)::numeric, 2) AS \"가격\",\n  ROUND(COALESCE(fee, 0)::numeric, 4) AS \"수수료\",\n  ROUND(COALESCE(pnl, 0)::numeric, 4) AS \"PnL\",\n  status AS \"상태\"\nFROM trades\nORDER BY COALESCE(filled_at, created_at) DESC\nLIMIT 50", "refId": "A"}],
