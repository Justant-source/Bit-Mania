        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cryptoengine-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH data AS (\n  SELECT\n    date_trunc('hour', opened_at) as time,\n    ROUND(entry_price / 500) * 500 as price_bucket,\n    COUNT(*) as count\n  FROM positions\n  WHERE $__timeFilter(opened_at)\n    AND ('$strategy' = '.*' OR strategy_id = '$strategy')\n  GROUP BY 1, 2\n)\nSELECT * FROM data\nUNION ALL\nSELECT NOW(), 65000.0, 0\nWHERE NOT EXISTS (SELECT 1 FROM data)\nORDER BY 1, 2",
          "refId": "A"
        }
      ],
      "title": "Entry Price Level Heatmap",
      "type": "heatmap"
    },

