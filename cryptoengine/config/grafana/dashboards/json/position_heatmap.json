          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  strategy_id,\n  side,\n  COUNT(*) as total_trades,\n  COUNT(CASE WHEN unrealized_pnl > 0 THEN 1 END) as wins,\n  ROUND(COUNT(CASE WHEN unrealized_pnl > 0 THEN 1 END) * 100.0 / NULLIF(COUNT(*), 0), 1) as win_rate_pct,\n  ROUND(SUM(unrealized_pnl)::numeric, 2) as total_pnl,\n  ROUND(AVG(unrealized_pnl)::numeric, 2) as avg_pnl\nFROM positions\nWHERE closed_at IS NOT NULL\nGROUP BY strategy_id, side\nORDER BY strategy_id, side",
          "refId": "A"
        }
      ],
      "title": "Strategy Performance Matrix",
      "type": "table"
