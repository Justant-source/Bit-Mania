          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND(entry_price / 500) * 500 as price_range,\n  SUM(unrealized_pnl) as total_pnl,\n  COUNT(*) as trade_count,\n  AVG(unrealized_pnl) as avg_pnl\nFROM positions\nWHERE\n  closed_at IS NOT NULL\n  AND ('$strategy' = '.*' OR strategy_id = '$strategy')\nGROUP BY 1\nORDER BY 1",
