          "rawSql": "SELECT\n  date AS \"날짜\",\n  ROUND(COALESCE(starting_equity, 0)::numeric, 2) AS \"시작 자산\",\n  ROUND(COALESCE(ending_equity, 0)::numeric, 2) AS \"종료 자산\",\n  ROUND(COALESCE(funding_income, 0)::numeric, 4) AS \"펀딩 수입\",\n  ROUND(COALESCE(\n    (SELECT -SUM(ABS(COALESCE(fee, 0))) FROM trades WHERE DATE(filled_at) = dr.date),\n    0\n  )::numeric, 4) AS \"수수료\",\n  ROUND(COALESCE(daily_pnl, 0)::numeric, 4) AS \"순손익\",\n  ROUND((COALESCE(daily_return, 0) * 100)::numeric, 3) AS \"수익률 (%)\",\n  COALESCE(trade_count, 0) AS \"거래 횟수\",\n  ROUND((COALESCE(max_drawdown, 0) * 100)::numeric, 3) AS \"최대 DD (%)\"\nFROM daily_reports dr\nORDER BY date DESC\nLIMIT 30",
