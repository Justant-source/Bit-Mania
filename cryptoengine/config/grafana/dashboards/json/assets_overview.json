    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
      "description": "현재 오픈 포지션 기준 BTC 포지션 가치 vs 나머지 USDT 추정 자산",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "mappings": [],
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        },
        "pieType": "pie",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH btc_pos AS (\n  SELECT COALESCE(SUM(size * current_price), 0) AS btc_value\n  FROM positions WHERE closed_at IS NULL AND side = 'buy'\n),\ntotal AS (\n  SELECT COALESCE(total_equity, 0) AS equity\n  FROM portfolio_snapshots ORDER BY snapshot_at DESC LIMIT 1\n)\nSELECT '선물 포지션 증거금' AS \"자산 구분\", COALESCE(btc_value, 0) AS \"금액 (USDT)\" FROM btc_pos\nUNION ALL\nSELECT 'USDT 잔고 (추정)', GREATEST(equity - COALESCE(btc_value, 0), 0) FROM total, btc_pos",
          "refId": "A"
        }
      ],
      "title": "자산 구성 비율",
      "type": "piechart"
    },

