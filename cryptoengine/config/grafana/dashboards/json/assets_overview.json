            "uid": "cryptoengine-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'BTC (포지션)' AS asset,\n  COALESCE(SUM(size * entry_price / NULLIF(leverage, 1)), 0) AS value\nFROM positions WHERE closed_at IS NULL AND symbol = 'BTCUSDT'",
          "refId": "B"
