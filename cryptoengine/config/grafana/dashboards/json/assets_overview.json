          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 'USDT (현금)' AS asset,\n  GREATEST(\n    ps.total_equity - COALESCE(\n      (SELECT SUM(size * entry_price / NULLIF(leverage, 1)) FROM positions WHERE closed_at IS NULL),\n      0\n    ),\n    0\n  ) AS value\nFROM (SELECT COALESCE((SELECT total_equity FROM portfolio_snapshots ORDER BY snapshot_at DESC LIMIT 1), 0) AS total_equity) ps",
          "refId": "A"
        },
        {
          "datasource": {
