        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH current AS (\n  SELECT regime, detected_at FROM market_regime_history WHERE symbol = '$symbol' ORDER BY detected_at DESC LIMIT 1\n),\nprev_change AS (\n  SELECT h.detected_at AS changed_at\n  FROM market_regime_history h, current c\n  WHERE h.symbol = '$symbol' AND h.regime != c.regime\n  ORDER BY h.detected_at DESC LIMIT 1\n)\nSELECT ROUND(EXTRACT(EPOCH FROM (NOW() - COALESCE(prev_change.changed_at, NOW() - INTERVAL '999 hours')))/3600, 1) AS hours_in_regime\nFROM current LEFT JOIN prev_change ON true",
          "refId": "A"
        }
      ],
