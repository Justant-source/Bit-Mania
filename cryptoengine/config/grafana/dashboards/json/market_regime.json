      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) - 1 AS switches FROM (\n  SELECT regime, LAG(regime) OVER (ORDER BY detected_at) AS prev_regime\n  FROM market_regime_history\n  WHERE symbol = '$symbol' AND detected_at >= CURRENT_DATE\n) t WHERE regime != COALESCE(prev_regime, regime)",
          "refId": "A"
        }
      ],
