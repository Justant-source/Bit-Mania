      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cryptoengine-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT * FROM (\n  SELECT 'ohlcv_history' AS \"테이블\", COUNT(*) AS \"건수\", MAX(timestamp) AS \"최신 레코드\" FROM ohlcv_history\n  UNION ALL SELECT 'portfolio_snapshots', COUNT(*), MAX(snapshot_at) FROM portfolio_snapshots\n  UNION ALL SELECT 'positions (오픈)', COUNT(*), MAX(opened_at) FROM positions WHERE closed_at IS NULL\n  UNION ALL SELECT 'trades', COUNT(*), MAX(COALESCE(filled_at, created_at)) FROM trades\n  UNION ALL SELECT 'funding_payments', COUNT(*), MAX(collected_at) FROM funding_payments\n  UNION ALL SELECT 'funding_rate_history', COUNT(*), MAX(timestamp) FROM funding_rate_history\n  UNION ALL SELECT 'daily_reports', COUNT(*), MAX(date::timestamptz) FROM daily_reports\n  UNION ALL SELECT 'llm_reports', COUNT(*), MAX(created_at) FROM llm_reports\n) t ORDER BY \"테이블\"",
          "refId": "A"
        }
      ],
      "title": "DB 테이블 현황",
