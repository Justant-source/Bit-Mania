      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cryptoengine-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT * FROM (\n  SELECT 1 AS sort_order,\n    '① 펀딩비율 ≥ 임계값' AS \"진입 조건\",\n    ROUND((rate * 100)::numeric, 4) || '% / 8h' AS \"현재값\",\n    '0.0120% / 8h' AS \"임계값\",\n    CASE WHEN rate >= 0.00012 THEN '✅ 충족'\n      ELSE '❌ 미충족 (연 ' || ROUND((rate * 3 * 365 * 100)::numeric, 1) || '% < 25%)'\n    END AS \"상태\"\n  FROM funding_rate_history WHERE symbol = 'BTCUSDT' ORDER BY timestamp DESC LIMIT 1\n\n  UNION ALL\n\n  SELECT 2, '② 연속 4틱 초과',\n    (SELECT SUM(CASE WHEN rate >= 0.00012 THEN 1 ELSE 0 END) FROM (SELECT rate FROM funding_rate_history WHERE symbol='BTCUSDT' ORDER BY timestamp DESC LIMIT 4) r)::text || ' / 4',\n    '4 연속', '❌ 미충족 (실시간 카운터는 전략 내부)'\n\n  UNION ALL\n\n  SELECT 3, '③ BEP 순수익성 (2사이클)',\n    ROUND((rate * 150 * 5 * 2)::numeric, 4) || ' - ' || ROUND((150 * 0.00130 * 2)::numeric, 4) || ' USDT',\n    '> 0 USDT',\n    CASE WHEN (rate * 150 * 5 * 2 - 150 * 0.00130 * 2) > 0 THEN '✅ 충족'\n      ELSE '❌ 미충족 (수수료 > 펀딩수익)' END\n  FROM funding_rate_history WHERE symbol = 'BTCUSDT' ORDER BY timestamp DESC LIMIT 1\n\n  UNION ALL\n\n  SELECT 4, '④ 빈 포지션 슬롯',\n    (SELECT COUNT(*) FROM positions WHERE closed_at IS NULL AND strategy_id='funding_arb')::text || ' / 1',\n    '< 1',\n    CASE WHEN (SELECT COUNT(*) FROM positions WHERE closed_at IS NULL AND strategy_id='funding_arb') < 1 THEN '✅ 충족 (빈 슬롯)' ELSE '❌ 미충족' END\n\n  UNION ALL\n\n  SELECT 5, '⑤ Kill Switch 비활성',\n    CASE WHEN EXISTS (SELECT 1 FROM kill_switch_events WHERE resolved_at IS NULL) THEN '활성 (차단)' ELSE '비활성 (정상)' END,\n    '비활성',\n    CASE WHEN NOT EXISTS (SELECT 1 FROM kill_switch_events WHERE resolved_at IS NULL) THEN '✅ 충족' ELSE '❌ 미충족' END\n) sub ORDER BY sort_order",
          "refId": "A"
        }
      ],
      "title": "FA 진입 조건 상세",
      "type": "table"
    },
