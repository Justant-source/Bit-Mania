    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
      "description": "Orchestrator가 각 전략에 할당한 자본 및 현재 운영 상태",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": false,
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "실행 중" },
            "properties": [{
              "id": "mappings",
              "value": [
                { "options": { "true":  { "color": "green", "index": 0, "text": "● 실행 중" },
                               "false": { "color": "gray",  "index": 1, "text": "○ 정지" }
                  }, "type": "value" }
              ]
            }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }]
          },
          {
            "matcher": { "id": "byName", "options": "배분 자본" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "현재 PnL" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  strategy_id AS \"전략 ID\",\n  is_running::text AS \"실행 중\",\n  allocated_capital AS \"배분 자본\",\n  current_pnl AS \"현재 PnL\",\n  position_count AS \"포지션 수\",\n  updated_at AS \"최근 업데이트\"\nFROM strategy_states\nORDER BY strategy_id",
          "refId": "A"
        }
      ],
      "title": "전략별 실행 상태",
      "type": "table"
    },

