          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  triggered_at AS \"발동 시간\",\n  level AS \"레벨\",\n  reason AS \"이유\",\n  positions_closed AS \"청산 포지션 수\",\n  pnl_at_trigger AS \"PnL at 발동\",\n  resolved_at AS \"해제 시간\"\nFROM kill_switch_events\nORDER BY triggered_at DESC\nLIMIT 20",
          "refId": "A"
