    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
      "description": "LLM Advisor가 실행한 분석 요청 및 결과 이력 — 트리거 유형과 판단 내용 포함",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
