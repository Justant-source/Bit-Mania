                    "unknown":       { "color": "gray",   "index": 5, "text": "? 불명" }
                  }, "type": "value" }
              ]
            }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }]
          },
          {
            "matcher": { "id": "byName", "options": "신뢰도" },
            "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "decimals", "value": 2 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  detected_at AS \"감지 시간\",\n  symbol AS \"심볼\",\n  regime AS \"레짐\",\n  confidence AS \"신뢰도\"\nFROM market_regime_history\nWHERE $__timeFilter(detected_at)\nORDER BY detected_at DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "레짐 변화 이력",
      "type": "table"
    },

