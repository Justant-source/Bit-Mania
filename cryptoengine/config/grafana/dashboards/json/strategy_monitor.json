          "rawQuery": true,
          "rawSql": "SELECT\n  timestamp AS time,\n  rate AS \"펀딩비율\"\nFROM funding_rate_history\nWHERE symbol = 'BTCUSDT'\n  AND $__timeFilter(timestamp)\nORDER BY timestamp",
