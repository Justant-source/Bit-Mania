      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "cryptoengine-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  created_at AS \"분석 시간\",\n  trigger AS \"트리거\",\n  rating AS \"판단\",\n  ROUND(confidence * 100, 1) AS \"신뢰도\",\n  regime AS \"레짐\",\n  COALESCE(\n    CASE WHEN risk_assessment LIKE '{%' THEN (risk_assessment::json->>'risk_assessment') ELSE risk_assessment END,\n    '없음'\n  ) AS \"리스크 평가\"\nFROM llm_reports\nWHERE $__timeFilter(created_at)\nORDER BY created_at DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "LLM 분석 요청/결과 이력",
      "type": "table"
