          "rawSql": "SELECT\n  strategy_id AS \"전략\",\n  symbol AS \"심볼\",\n  side AS \"방향\",\n  ROUND(size::numeric, 4) AS \"수량(BTC)\",\n  ROUND(entry_price::numeric, 2) AS \"진입가\",\n  ROUND(current_price::numeric, 2) AS \"현재가\",\n  ROUND(unrealized_pnl::numeric, 4) AS \"미실현PnL\",\n  ROUND(leverage::numeric, 1) AS \"레버리지\",\n  opened_at AS \"진입시간\"\nFROM positions\nWHERE closed_at IS NULL\nORDER BY opened_at DESC",
