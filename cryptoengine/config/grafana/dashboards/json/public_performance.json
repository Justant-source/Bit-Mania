      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cryptoengine-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH daily AS (\n  SELECT date_trunc('day', created_at) AS day, SUM(pnl) AS pnl\n  FROM trades WHERE status = 'closed'\n  GROUP BY 1\n),\nstats AS (\n  SELECT AVG(pnl) AS mean_pnl, STDDEV(pnl) AS std_pnl FROM daily\n)\nSELECT\n  CASE WHEN std_pnl > 0 THEN (mean_pnl / std_pnl) * SQRT(365) ELSE 0 END AS sharpe\nFROM stats",
          "refId": "A"
        }
      ],
      "title": "Sharpe Ratio (est.)",
      "type": "stat"
    },
