node_modules/
.idea/
/.request/
/.result/
/cryptoengine/.env

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Claude Code runtime
.claude/scheduled_tasks.lock

# Backtest input data (large binary, re-downloadable)
cryptoengine/backtest-results/data/

# Jesse backtest runtime artifacts (UUID raw results)
cryptoengine/services/jesse_engine/storage/json/

# LLM Advisor data source runtime files
cryptoengine/services/llm-advisor/alerts/*.md
cryptoengine/services/llm-advisor/logs/*.log
cryptoengine/services/llm-advisor/cache/
!cryptoengine/services/llm-advisor/alerts/.gitkeep
!cryptoengine/services/llm-advisor/logs/.gitkeep
!cryptoengine/services/llm-advisor/cache/.gitkeep
